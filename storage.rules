rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Fotos de ofertas: cada lojista só grava na própria pasta (uid como prefixo do caminho).
    // Leitura pública, pois as fotos aparecem no feed de qualquer cliente.
    match /deals/{merchantId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == merchantId;
    }
  }
}