<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="theme-color" content="#2196F3" />
    <meta name="robots" content="noindex" />
    <meta
      name="description"
      content="Painel de gerenciamento de ofertas para lojistas - Radar de Ofertas"
    />
    <title>Radar de Ofertas - Painel do Lojista</title>

    <!-- Preconnect for better performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link rel="stylesheet" href="/merchant/css/merchant.css" />
  </head>
  <body>
    <!-- Loading Screen -->
    <div
      id="loading"
      class="loading"
      role="status"
      aria-label="Carregando aplicativo"
    >
      <div class="loading-content">
        <div class="logo-spinner">
          <img
            src="/public/assets/icons/icon-192.png"
            alt="RadarOfertas"
            class="loading-logo"
          />
          <div class="spinner-ring"></div>
        </div>
        <p class="loading-text">Carregando painel...</p>
      </div>
    </div>

    <!-- Login Screen -->
    <div
      id="login-screen"
      class="screen hidden"
      role="dialog"
      aria-labelledby="login-title"
    >
      <div class="login-container">
        <div class="login-header">
          <img
            src="/public/assets/icons/icon-192.png"
            alt="Radar de Ofertas - Painel do Lojista"
            class="logo"
          />
          <h1 id="login-title" class="brand-title">Radar de Ofertas Lojista</h1>
          <p class="brand-subtitle">
            Conecte-se com milhares de clientes e multiplique suas vendas
          </p>
        </div>
        <div class="login-content">
          <button
            id="google-login-btn"
            class="btn-primary"
            aria-label="Entrar com Google"
          >
            <img
              src="/public/assets/icons/google.svg"
              alt="Google"
              class="google-icon"
            />
            <span>Entrar com Google</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Main Panel -->
    <div id="panel" class="hidden">
      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <h2>🏪 Radar de Ofertas</h2>
          <p class="role-badge">Lojista</p>
        </div>

        <nav class="sidebar-nav">
          <button class="nav-btn active" data-view="deals">
            <span>🏷️</span>
            <span>Minhas Ofertas</span>
          </button>
          <button class="nav-btn" data-view="create-deal">
            <span>➕</span>
            <span>Nova Oferta</span>
          </button>
          <button class="nav-btn" data-view="validate">
            <span>✅</span>
            <span>Validar Cupom</span>
          </button>
          <button class="nav-btn" data-view="stats">
            <span>📊</span>
            <span>Estatísticas</span>
          </button>
        </nav>

        <div class="sidebar-footer">
          <div class="user-info">
            <img id="user-photo" class="avatar" alt="User" />
            <div>
              <p id="user-name">Carregando...</p>
              <button id="logout-btn" class="btn-text">Sair</button>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="main-content">
        <!-- View: Minhas Ofertas -->
        <div id="view-deals" class="view active">
          <div class="view-header">
            <h1>Minhas Ofertas</h1>
            <button class="btn-primary" onclick="showView('create-deal')">
              ➕ Nova Oferta
            </button>
          </div>
          <div id="deals-list" class="deals-list">
            <!-- Deals serão inseridos aqui -->
          </div>
        </div>
        
<!-- View: Criar Oferta -->
<div id="view-create-deal" class="view">
  <div class="view-header">
    <button class="btn-back" onclick="showView('deals')">← Voltar</button>
    <h1>Nova Oferta</h1>
  </div>

  <form id="deal-form" class="form-container">
    <!-- Título e Descrição -->
    <div class="form-group">
      <label>Título da Oferta *</label>
      <input
        type="text"
        id="deal-title"
        required
        placeholder="Ex: Pizza Margherita 50% OFF"
      />
    </div>

    <div class="form-group">
      <label>Descrição *</label>
      <textarea
        id="deal-description"
        required
        rows="3"
        placeholder="Descreva os detalhes da oferta..."
      ></textarea>
    </div>

    <!-- Preços -->
    <div class="form-row">
      <div class="form-group">
        <label>Preço Original (R$) *</label>
        <input
          type="number"
          id="deal-original-price"
          required
          step="0.01"
          min="0"
          placeholder="40.00"
        />
      </div>

      <div class="form-group">
        <label>Preço com Desconto (R$) *</label>
        <input
          type="number"
          id="deal-price"
          required
          step="0.01"
          min="0"
          placeholder="20.00"
        />
      </div>

      <div class="form-group">
        <label>Desconto (%)</label>
        <input
          type="number"
          id="deal-discount"
          readonly
          placeholder="Calculado automaticamente"
        />
      </div>
    </div>

    <!-- Estoque, Categoria e Validade -->
    <div class="form-row">
      <div class="form-group">
        <label>Estoque Total *</label>
        <input
          type="number"
          id="deal-stock"
          required
          min="1"
          placeholder="100"
        />
      </div>

      <div class="form-group">
        <label>Categoria *</label>
        <select id="deal-category" required>
          <option value="">Selecione...</option>
          <option value="supermarket">Supermercado</option>
          <option value="pharmacy">Farmácia</option>
          <option value="bakery">Padaria</option>
          <option value="restaurant">Restaurante</option>
          <option value="petshop">Pet Shop</option>
          <option value="utilities">Utilidades</option>
          <option value="clothing">Vestuário</option>
          <option value="electronics">Eletrônicos</option>
          <option value="services">Serviços</option>
          <option value="other">Outro</option>
        </select>
      </div>

      <div class="form-group">
        <label>Válido até *</label>
        <input type="date" id="deal-expires" required />
      </div>
    </div>

    <!-- LOCALIZAÇÃO (Simplificada) -->
    <h3
      style="
        margin: 32px 0 16px 0;
        color: #1e293b;
        padding-top: 16px;
        border-top: 1px solid #e2e8f0;
      "
    >
      📍 Localização do Estabelecimento
    </h3>

    <div class="form-group">
      <label>Endereço Completo *</label>
      <input
        type="text"
        id="deal-address"
        required
        placeholder="Av. Paulista, 1000 - Bela Vista, São Paulo - SP, 01310-100"
      />
      <small style="color: #64748b; font-size: 0.875rem">
        Digite endereço completo com CEP. As coordenadas serão geradas
        automaticamente.
      </small>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Bairro *</label>
        <input
          type="text"
          id="deal-neighborhood"
          required
          placeholder="Bela Vista"
        />
      </div>

      <div class="form-group">
        <label>Raio de Atendimento *</label>
        <select id="deal-radius" required>
          <option value="">Selecione...</option>
          <option value="1">1 km (muito próximo)</option>
          <option value="2">2 km</option>
          <option value="3">3 km</option>
          <option value="5" selected>5 km (recomendado)</option>
          <option value="10">10 km</option>
          <option value="15">15 km</option>
          <option value="20">20 km (máximo)</option>
        </select>
        <small style="color: #64748b; font-size: 0.875rem">
          Distância máxima que os clientes podem estar para ver sua oferta
        </small>
      </div>

      <!-- Campo oculto para tipo de entrega (fixo como retirada) -->
      <input type="hidden" id="delivery-type" value="pickup" />
    </div>

    <!-- UPLOAD DE IMAGEM (Novo) -->
    <h3
      style="
        margin: 32px 0 16px 0;
        color: #1e293b;
        padding-top: 16px;
        border-top: 1px solid #e2e8f0;
      "
    >
      🖼️ Imagem da Oferta
    </h3>

    <div class="form-group">
      <label>Imagem da Oferta</label>

      <!-- Preview da Imagem -->
      <div id="image-preview" class="image-preview" style="display: none">
        <img
          id="preview-image"
          src=""
          alt="Prévia da imagem"
          style="
            width: 100%;
            max-width: 300px;
            border-radius: 8px;
            margin-bottom: 12px;
          "
        />
        <button
          type="button"
          id="remove-image-btn"
          class="btn-secondary"
          style="padding: 6px 12px; font-size: 0.875rem"
        >
          ✕ Remover Imagem
        </button>
      </div>

      <!-- Upload Container -->
      <div id="upload-container" class="upload-container">
        <!-- Upload via Arquivo -->
        <div class="upload-option" style="margin-bottom: 16px">
          <label
            for="deal-image-file"
            class="upload-label"
            style="
              display: block;
              cursor: pointer;
              padding: 24px;
              border: 2px dashed #cbd5e1;
              border-radius: 12px;
              text-align: center;
              transition: all 0.3s;
            "
          >
            <div style="font-size: 2.5rem; margin-bottom: 12px">📁</div>
            <div style="font-weight: 500; color: #334155; margin-bottom: 8px">
              Escolher arquivo do computador
            </div>
            <div style="font-size: 0.875rem; color: #64748b">
              Clique para selecionar uma imagem (JPG, PNG - Máx. 2MB)
            </div>
            <input
              type="file"
              id="deal-image-file"
              accept="image/*"
              style="display: none"
            />
          </label>
        </div>

        <!-- Divider -->
        <div style="text-align: center; margin: 20px 0; position: relative">
          <span
            style="
              background: white;
              padding: 0 12px;
              color: #94a3b8;
              font-size: 0.875rem;
            "
            >ou</span
          >
          <div
            style="
              height: 1px;
              background: #e2e8f0;
              position: absolute;
              top: 50%;
              left: 0;
              right: 0;
              z-index: -1;
            "
          ></div>
        </div>

        <!-- Upload via URL (opcional) -->
        <div class="upload-option">
          <div style="margin-bottom: 8px; font-weight: 500; color: #334155">
            Usar link da internet
          </div>
          <input
            type="url"
            id="deal-image-url"
            placeholder="https://exemplo.com/imagem.jpg"
            style="
              width: 100%;
              padding: 12px;
              border: 1px solid #cbd5e1;
              border-radius: 8px;
            "
          />
          <small
            style="
              color: #64748b;
              font-size: 0.875rem;
              display: block;
              margin-top: 6px;
            "
          >
            Cole o link de uma imagem hospedada online (opcional)
          </small>
        </div>
      </div>

      <!-- Status do Upload -->
      <div
        id="upload-status"
        style="
          display: none;
          padding: 12px;
          background: #f0f9ff;
          border-radius: 8px;
          margin-top: 12px;
        "
      >
        <div style="display: flex; align-items: center; gap: 8px">
          <div class="spinner-small"></div>
          <span style="color: #0369a1">Processando imagem...</span>
        </div>
      </div>
    </div>

    <!-- Botões de Ação -->
    <div class="form-actions">
      <button type="button" class="btn-secondary" onclick="showView('deals')">
        Cancelar
      </button>
      <button type="submit" class="btn-primary">Publicar Oferta</button>
    </div>
  </form>
</div>
