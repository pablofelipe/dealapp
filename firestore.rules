rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Deals
    match /deals/{dealId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
                       (resource.data.merchantId == request.auth.uid ||
                        request.resource.data.stockAvailable == resource.data.stockAvailable - 1);
      allow delete: if isAuthenticated() && 
                       resource.data.merchantId == request.auth.uid;
    }
    
    // Coupons - permitir criar e ler próprios cupons
    match /coupons/{couponId} {
      // Leitura: dono do cupom OU qualquer autenticado (para lojista validar)
      allow read: if isAuthenticated();
      
      // Criação: apenas se o userId do cupom for o próprio usuário
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Atualização: dono do cupom OU se estiver marcando como resgatado
      allow update: if isAuthenticated();
    }
    
    // Users - O dono acessa tudo, lojistas autenticados podem atualizar economia no resgate
    match /users/{userId} {
      allow read: if isAuthenticated(); // Lojista precisa ler para ver nome/foto do cliente
      
      allow write: if isAuthenticated();
    }
    
    match /merchants/{userId} {
      allow read: if true; // Qualquer um vê ofertas
      
      // Permite criar com qualquer campo (incluindo o vendorCode opcional)
      allow create: if request.auth != null;

      // No update, garantimos que o vendorCode enviado é IGUAL ao que já estava lá
      // Ou seja: o lojista não pode mudar o valor que foi definido no cadastro.
      allow update: if isAuthenticated() && request.auth.uid == userId 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['vendorCode']) 
                        || request.resource.data.vendorCode == resource.data.vendorCode);
    }
  }
}