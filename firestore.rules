rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Deals
    match /deals/{dealId} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Estoque/cupom são geridos pelas Cloud Functions generateCoupon/redeemCoupon (Admin SDK,
      // que ignora estas regras) - o client não decrementa stockAvailable diretamente.
      allow update: if isAuthenticated() && resource.data.merchantId == request.auth.uid;
      allow delete: if isAuthenticated() && 
                       resource.data.merchantId == request.auth.uid;
    }
    
    // Coupons - emitidos e resgatados apenas via Cloud Functions (generateCoupon/redeemCoupon),
    // que usam o Admin SDK e por isso ignoram estas regras. O client só lê.
    match /coupons/{couponId} {
      // Leitura: dono do cupom OU qualquer autenticado (para lojista validar)
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if false;
    }

    // Users - O dono acessa tudo. Os campos de economia (totalSavings/dealsPurchased/lastActivity)
    // são gravados pela Cloud Function redeemCoupon (Admin SDK), não pelo client.
    match /users/{userId} {
      allow read: if isAuthenticated(); // Lojista precisa ler para ver nome/foto do cliente
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /merchants/{userId} {
      allow read: if true; // Qualquer um vê ofertas
      
      // Permite criar com qualquer campo (incluindo o vendorCode opcional)
      allow create: if request.auth != null;

      // No update, garantimos que o vendorCode enviado é IGUAL ao que já estava lá
      // Ou seja: o lojista não pode mudar o valor que foi definido no cadastro.
      allow update: if isAuthenticated() && request.auth.uid == userId 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['vendorCode']) 
                        || request.resource.data.vendorCode == resource.data.vendorCode);
    }
  }
}